<div class="container mx-auto px-4 py-8 max-w-4xl">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-black text-gray-900 tracking-tight">
      <% # 1. Check if the user has permission to manage all bookings (Admin behavior) %>
      <%= can?(:manage, :all) ? "Master Booking Ledger (Admin)" : "Your Ticket Wallet" %>
    </h1>
    <span class="bg-gray-100 text-gray-800 text-xs font-semibold px-3 py-1 rounded-full border border-gray-200">
      Total Records: <%= @bookings.size %>
    </span>
  </div>

  <% if @bookings.blank? %>
    <div class="text-center py-12 bg-gray-50 rounded-2xl border border-dashed border-gray-200">
      <p class="text-gray-500 font-medium">No booking records found.</p>
      <%= link_to "Browse Showtimes", root_path, class: "mt-4 inline-block text-indigo-600 font-bold hover:underline" %>
    </div>
  <% else %>
    <div class="overflow-hidden bg-white border border-gray-200 rounded-2xl shadow-sm">
      <table class="min-w-full divide-y divide-gray-200 text-left text-sm">
        <thead class="bg-gray-50 text-xs uppercase tracking-wider text-gray-500 font-bold">
          <tr>
            <th class="px-6 py-4">Booking ID</th>
            <% # 2. Only show the header column if the user can read bookings belonging to other users %>
            <% if can?(:manage, Booking) %>
              <th class="px-6 py-4">Customer Email</th>
            <% end %>
            <th class="px-6 py-4">Movie</th>
            <th class="px-6 py-4">Showtime Date & Time</th>
            <th class="px-6 py-4">Total Paid</th>
            <th class="px-6 py-4">Status</th>
            <th class="px-6 py-4 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 font-medium text-gray-900">
          <% @bookings.each do |booking| %>
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-6 py-4 font-mono text-gray-400">#<%= booking.id %></td>
              <% # 3. Securely check if user has access to read details of this specific booking asset %>
              <% if can?(:manage, Booking) %>
                <td class="px-6 py-4 text-indigo-600 font-semibold"><%= booking.user.email %></td>
              <% end %>
              <td class="px-6 py-4 font-bold"><%= booking.showtime.movie.title %></td>
              <td class="px-6 py-4 text-gray-600">
                <%= booking.showtime.start_time.strftime("%b %d, %Y • %I:%M %p") %>
              </td>
              <td class="px-6 py-4"><%= number_to_currency(booking.total_price) %></td>
              <td class="px-6 py-4">
                <span class="inline-block px-2.5 py-1 rounded-full text-xs font-bold uppercase tracking-wider <%= booking.status == 'confirmed' || booking.status == 'pending' ? 'bg-emerald-50 text-emerald-700 border border-emerald-200' : 'bg-gray-100 text-gray-600' %>">
                  <%= booking.status %>
                </span>
              </td>
              <td class="px-6 py-4 text-right">
                <% # 4. Render the Action item link button only if the current user is authorized to read it %>
                <% if can?(:read, booking) %>
                  <%= link_to "View", booking_path(booking), class: "inline-block bg-gray-900 hover:bg-gray-800 text-white text-xs px-3 py-1.5 rounded-lg transition" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>