<div class="container mx-auto px-4 py-8 max-w-5xl">
  
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
    <div>
      <h1 class="text-3xl font-black text-white tracking-tight drop-shadow-sm">
        <%= can?(:manage, :all) ? "Master Booking Ledger (Admin)" : "Your Ticket Wallet" %>
      </h1>
      <p class="text-white/70 text-sm mt-1 font-medium">Manage entry records, track receipts, and display digital passes.</p>
    </div>
    <span class="bg-white/10 backdrop-blur-md text-white text-xs font-bold px-4 py-2 rounded-xl border border-white/10 shadow-sm">
      Total Records: <%= @bookings.size %>
    </span>
  </div>

  <% if @bookings.blank? %>
    <div class="text-center py-16 bg-white/10 backdrop-blur-lg rounded-3xl border border-white/10 shadow-xl">
      <div class="text-4xl mb-4">🎟️</div>
      <p class="text-white font-semibold text-lg">No booking records found.</p>
      <p class="text-white/60 text-sm mt-1 mb-6">Your active inventory index is currently completely empty.</p>
      <%= link_to "Browse Showtimes", root_path, class: "inline-block bg-white hover:bg-orange-50 text-stone-900 font-extrabold px-6 py-3 rounded-xl shadow-md transition tracking-tight text-sm" %>
    </div>
  <% else %>
    <div class="overflow-hidden bg-stone-900/40 backdrop-blur-xl border border-white/10 rounded-3xl shadow-2xl">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-white/5 text-left text-sm">
          
          <thead class="bg-white/5 text-xs uppercase tracking-wider text-orange-200/80 font-extrabold">
            <tr>
              <th class="px-6 py-4">Booking ID</th>
              <% if can?(:manage, Booking) %>
                <th class="px-6 py-4">Customer Email</th>
              <% end %>
              <th class="px-6 py-4">Movie</th>
              <th class="px-6 py-4">Showtime Date & Time</th>
              <th class="px-6 py-4">Total Paid</th>
              <th class="px-6 py-4">Status</th>
              <th class="px-6 py-4 text-right">Actions</th>
            </tr>
          </thead>
          
          <tbody class="divide-y divide-white/5 font-medium text-white">
            <% @bookings.each do |booking| %>
              <tr class="hover:bg-white/5 transition-colors duration-150">
                
                <td class="px-6 py-4 font-mono text-white/40 text-xs">#<%= booking.id %></td>
                
                <% if can?(:manage, Booking) %>
                  <td class="px-6 py-4 text-orange-200 font-semibold text-xs tracking-wide"><%= booking.user.email %></td>
                <% end %>
                
                <td class="px-6 py-4 font-black text-white text-base tracking-tight"><%= booking.showtime.movie.title %></td>
                
                <td class="px-6 py-4 text-white/80 font-normal text-xs">
                  <%= booking.showtime.start_time.strftime("%b %d, %Y • %I:%M %p") %>
                </td>
                
                <td class="px-6 py-4 font-bold text-white"><%= number_to_currency(booking.total_price) %></td>
                
                <td class="px-6 py-4">
                  <% if booking.status == 'confirmed' || booking.status == 'pending' %>
                    <span class="inline-block px-3 py-1 rounded-lg text-[11px] font-black uppercase tracking-wider bg-emerald-500/20 text-emerald-300 border border-emerald-500/30">
                      <%= booking.status %>
                    </span>
                  <% else %>
                    <span class="inline-block px-3 py-1 rounded-lg text-[11px] font-black uppercase tracking-wider bg-white/10 text-white/60 border border-white/5">
                      <%= booking.status %>
                    </span>
                  <% end %>
                </td>
                
                <td class="px-6 py-4 text-right">
                  <% if can?(:read, booking) %>
                    <%= link_to "View Pass", booking_path(booking), class: "inline-block bg-white hover:bg-orange-50 text-stone-900 font-extrabold text-xs px-4 py-2 rounded-xl transition shadow-md tracking-tight" %>
                  <% end %>
                </td>
                
              </tr>
            <% end %>
          </tbody>
          
        </table>
      </div>
    </div>
  <% end %>
  
</div>