<div class="container mx-auto px-4 py-12 max-w-md">
  <% # 1. Wrap the entire ticket payload to guarantee authorization clearance %>
  <% if can?(:read, @booking) %>
    <div class="bg-white border border-gray-200 rounded-3xl shadow-xl overflow-hidden">
      
      <div class="bg-indigo-600 px-6 py-8 text-center text-white relative">
        <div class="w-8 h-8 bg-gray-100 rounded-full absolute -bottom-4 -left-4"></div>
        <div class="w-8 h-8 bg-gray-100 rounded-full absolute -bottom-4 -right-4"></div>
        
        <p class="text-xs uppercase tracking-widest text-indigo-200 font-bold mb-1">Booking Confirmed</p>
        <h1 class="text-2xl font-black"><%= @booking.showtime.movie.title %></h1>
      </div>

      <div class="p-6 border-b border-dashed border-gray-200 relative">
        <div class="space-y-4">
          <div class="flex justify-between text-sm">
            <span class="text-gray-400 font-medium">Date & Time</span>
            <span class="text-gray-900 font-semibold"><%= @booking.showtime.start_time.strftime("%b %d, %Y at %I:%M %p") %></span>
          </div>
          
          <div class="flex justify-between text-sm">
            <span class="text-gray-400 font-medium">Theater Screen</span>
            <span class="text-gray-900 font-semibold">Screen <%= @booking.showtime.screen.screen_number %></span>
          </div>

          <div class="flex justify-between text-sm">
            <span class="text-gray-400 font-medium">Seats Selected</span>
            <span class="text-indigo-600 font-bold">
              <% @tickets.each_with_index do |ticket, index| %>
                <%= ticket.showtime_seat.seat.row_name %><%= ticket.showtime_seat.seat.seat_number %><%= ',' if index < @tickets.size - 1 %>
              <% end %>
            </span>
          </div>
        </div>
      </div>

      <% # 2. Extra verification check: Only render entry QR codes if the user can interact with this asset %>
      <div class="p-6 bg-white flex flex-col items-center justify-center border-b border-dashed border-gray-200">
        <div class="p-4 bg-gray-50 border border-gray-200 rounded-2xl mb-3 shadow-inner">
          <div class="w-36 h-36 flex items-center justify-center">
            <%= @qr_code_svg.html_safe %>
          </div>
        </div>
        <p class="text-xs font-mono text-gray-400 tracking-widest">SCAN AT GATE • TICKET #<%= @booking.id %><%= @booking.user_id %></p>
      </div>

      <div class="p-6 bg-gray-50 flex justify-between items-center">
        <div>
          <p class="text-xs text-gray-400 font-bold uppercase tracking-wider">Total Price</p>
          <p class="text-2xl font-black text-gray-900"><%= number_to_currency(@booking.total_price) %></p>
        </div>
        
        <div>
          <span class="inline-block bg-emerald-100 text-emerald-800 text-xs font-bold px-3 py-1.5 rounded-full uppercase tracking-wider">
            <%= @booking.status.capitalize %>
          </span>
        </div>
      </div>
      
      <div class="p-6 bg-white text-center">
        <%= link_to "Back to Home", root_path, class: "block w-full bg-gray-900 hover:bg-gray-800 text-white font-semibold py-3 rounded-xl transition shadow" %>
      </div>

    </div>
  <% else %>
    <% # Fallback access warning layout block if security rules reject request %>
    <div class="text-center py-12 bg-white rounded-3xl border border-gray-200 shadow-xl p-6">
      <p class="text-red-500 font-bold text-lg mb-2">Access Denied</p>
      <p class="text-gray-500 text-sm mb-4">You are not authorized to view this ticket profile credential resource.</p>
      <%= link_to "Return to Dashboard", root_path, class: "inline-block bg-indigo-600 text-white text-sm font-semibold px-4 py-2 rounded-xl" %>
    </div>
  <% end %>
</div>