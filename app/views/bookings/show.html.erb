<div class="container mx-auto px-4 py-12 max-w-md">
  <% if can?(:read, @booking) %>
    <!-- PHYSICAL TICKET INNER CONTAINER -->
    <div class="bg-white rounded-[2rem] shadow-2xl overflow-hidden transform transition duration-300 hover:scale-[1.01]">
      
      <!-- TICKET HEADER: Styled with a rich magenta gradient matching your primary background element -->
      <div class="bg-gradient-to-r from-purple-900 to-[rgba(160,24,80,1)] px-6 py-8 text-center text-white relative">
        <!-- Ticket Punch Holes (Left & Right margins) -->
        <div class="w-8 h-8 bg-[rgba(160,24,80,1)] absolute -bottom-4 -left-4 rounded-full shadow-inner"></div>
        <div class="w-8 h-8 bg-[rgba(201,138,75,1)] absolute -bottom-4 -right-4 rounded-full shadow-inner"></div>
        
        <p class="text-[10px] uppercase tracking-[0.2em] text-pink-200/80 font-black mb-1">Admission Ticket</p>
        <h1 class="text-2xl font-black tracking-tight leading-tight"><%= @booking.showtime.movie.title %></h1>
      </div>

      <!-- SHOWTIME META METRICS -->
      <div class="p-8 border-b-2 border-dashed border-stone-100 relative bg-stone-50/50">
        <div class="space-y-4">
          <div class="flex justify-between items-center text-sm">
            <span class="text-stone-400 font-bold uppercase text-xs tracking-wider">Date & Time</span>
            <span class="text-stone-900 font-extrabold"><%= @booking.showtime.start_time.strftime("%b %d, %Y at %I:%M %p") %></span>
          </div>
          
          <div class="flex justify-between items-center text-sm">
            <span class="text-stone-400 font-bold uppercase text-xs tracking-wider">Theater Screen</span>
            <span class="text-stone-900 font-extrabold">Screen <%= @booking.showtime.screen.screen_number %></span>
          </div>

          <div class="flex justify-between items-center text-sm">
            <span class="text-stone-400 font-bold uppercase text-xs tracking-wider">Seats Selected</span>
            <span class="text-[rgba(160,24,80,1)] font-black tracking-wide text-base">
              <% @tickets.each_with_index do |ticket, index| %>
                <%= ticket.showtime_seat.seat.row_name %><%= ticket.showtime_seat.seat.seat_number %><%= ',' if index < @tickets.size - 1 %>
              <% end %>
            </span>
          </div>
        </div>
      </div>

      <!-- INTERACTIVE ENTRY GATE QR CODES -->
      <div class="p-8 bg-white flex flex-col items-center justify-center border-b-2 border-dashed border-stone-100">
        <div class="p-4 bg-stone-50 border border-stone-100 rounded-2xl mb-4 shadow-sm">
          <div class="w-40 h-40 flex items-center justify-center mix-blend-multiply">
            <%= @qr_code_svg.html_safe %>
          </div>
        </div>
        <p class="text-[11px] font-mono text-stone-400 tracking-[0.15em] font-medium">SCAN AT GATE • TICKET #<%= @booking.id %><%= @booking.user_id %></p>
      </div>

      <!-- RECEIPT SLIP AND INVENTORY METRICS -->
      <div class="p-8 bg-stone-50/70 flex justify-between items-center">
        <div>
          <p class="text-[10px] text-stone-400 font-black uppercase tracking-wider">Total Price</p>
          <p class="text-2xl font-black text-stone-900 tracking-tight"><%= number_to_currency(@booking.total_price) %></p>
        </div>
        
        <div>
          <span class="inline-block bg-emerald-500 text-white text-[11px] font-black px-4 py-2 rounded-xl uppercase tracking-wider shadow-sm shadow-emerald-500/20">
            <%= @booking.status.capitalize %>
          </span>
        </div>
      </div>
      
      <!-- NAVIGATIONAL DISMISS VIEW ACTION -->
      <div class="px-8 pb-8 pt-2 bg-white">
        <%= link_to "Return to Dashboard", root_path, class: "block w-full bg-stone-900 hover:bg-stone-800 text-white text-center font-extrabold py-3.5 rounded-xl transition shadow-lg tracking-tight text-sm" %>
      </div>

    </div>
  <% else %>
    <!-- SECURITY EXCEPTION AUTHC GUARD CARD -->
    <div class="text-center py-12 bg-white/10 backdrop-blur-xl rounded-[2rem] border border-white/10 shadow-2xl p-8">
      <div class="text-3xl mb-3">🛡️</div>
      <p class="text-white font-black text-xl mb-1">Access Denied</p>
      <p class="text-white/70 text-sm mb-6">You are not authorized to view this cinema pass credential resource.</p>
      <%= link_to "Return to Dashboard", root_path, class: "inline-block bg-white hover:bg-orange-50 text-stone-900 text-xs font-black px-5 py-3 rounded-xl transition shadow-md" %>
    </div>
  <% end %>
</div>