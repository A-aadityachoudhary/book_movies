<div class="container mx-auto px-4 py-12 max-w-md">
  <!-- FROSTED COMPACT PANEL CARD -->
  <div class="bg-stone-900/40 backdrop-blur-xl border border-white/10 rounded-[2rem] p-8 shadow-2xl">
    
    <!-- AUTH PANEL HEADER -->
    <div class="mb-8">
      <h2 class="text-2xl font-black text-white tracking-tight leading-tight">
        Change your password
      </h2>
      <p class="text-xs text-white/60 mt-1 font-medium">
        Set your new security authorization token credential string below.
      </p>
    </div>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-5" }) do |f| %>
      
      <% if resource.errors.any? %>
        <!-- ERROR MESSAGE CONSOLE CONTAINER -->
        <div class="p-4 bg-rose-500/20 border border-rose-500/30 rounded-2xl text-xs font-semibold text-rose-200">
          <%= render "devise/shared/error_messages", resource: resource %>
        </div>
      <% end %>
      
      <%= f.hidden_field :reset_password_token %>

      <!-- NEW PASSWORD INPUT FIELD -->
      <div>
        <div class="flex justify-between items-baseline mb-2">
          <%= f.label :password, "New Password", class: "block text-xs font-black uppercase tracking-wider text-orange-200/90" %>
          <% if @minimum_password_length %>
            <span class="text-[10px] text-white/40 font-bold uppercase tracking-wide italic">(<%= @minimum_password_length %> chars min)</span>
          <% end %>
        </div>
        <%= f.password_field :password, 
            autofocus: true, 
            autocomplete: "new-password", 
            placeholder: "••••••••",
            class: "block w-full bg-white/10 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/30 text-sm font-semibold focus:outline-none focus:ring-2 focus:ring-orange-300 focus:border-transparent transition shadow-inner" %>
      </div>

      <!-- CONFIRM PASSWORD INPUT FIELD -->
      <div>
        <%= f.label :password_confirmation, "Confirm New Password", class: "block text-xs font-black uppercase tracking-wider text-orange-200/90 mb-2" %>
        <%= f.password_field :password_confirmation, 
            autocomplete: "new-password", 
            placeholder: "••••••••",
            class: "block w-full bg-white/10 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/30 text-sm font-semibold focus:outline-none focus:ring-2 focus:ring-orange-300 focus:border-transparent transition shadow-inner" %>
      </div>

      <!-- SYSTEM TRANSACTION SUBMITTER ACTION -->
      <div class="pt-2">
        <%= f.submit "Change my password", 
            class: "block w-full bg-white hover:bg-orange-50 text-stone-900 font-extrabold text-sm py-3.5 rounded-xl transition shadow-lg cursor-pointer tracking-tight text-center" %>
      </div>
    <% end %>

    <!-- FOOTER NAVIGATIONAL DEVISE LINKS -->
    <div class="mt-8 pt-6 border-t border-white/5 text-center text-xs font-bold text-white/50 tracking-tight space-y-2">
      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>