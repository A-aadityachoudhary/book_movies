<div class="container mx-auto px-4 py-12 max-w-lg space-y-6">
  
  <!-- BACK NAVIGATION LINK -->
  <div class="text-left">
    <%= link_to "← Back", :back, class: "inline-flex items-center text-xs font-black uppercase tracking-wider text-white/50 hover:text-white transition" %>
  </div>

  <!-- MAIN EDIT PROFILE GLASS PANEL -->
  <div class="bg-stone-900/40 backdrop-blur-xl border border-white/10 rounded-[2rem] p-8 shadow-2xl">
    
    <div class="mb-8">
      <h1 class="text-2xl font-black text-white tracking-tight">Account Settings</h1>
      <p class="text-xs text-white/60 mt-1 font-medium">Update your email coordinates or security authorization passwords.</p>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-5" }) do |f| %>
      
      <% if resource.errors.any? %>
        <!-- FORM CUSTOM ERROR CONTAINER -->
        <div class="p-4 bg-rose-500/20 border border-rose-500/30 rounded-2xl text-xs font-semibold text-rose-200">
          <%= render "devise/shared/error_messages", resource: resource %>
        </div>
      <% end %>

      <!-- EMAIL INPUT FIELD -->
      <div>
        <%= f.label :email, class: "block text-xs font-black uppercase tracking-wider text-orange-200/90 mb-2" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", required: true,
            class: "block w-full bg-white/10 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/30 text-sm font-semibold focus:outline-none focus:ring-2 focus:ring-orange-300 focus:border-transparent transition shadow-inner" %>
      </div>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <!-- PENDING RECONFIRMATION STAMP -->
        <div class="p-3 bg-amber-500/10 border border-amber-500/20 rounded-xl text-xs text-amber-200 font-semibold tracking-wide">
          ⚠️ Waiting confirmation for: <span class="underline text-white"><%= resource.unconfirmed_email %></span>
        </div>
      <% end %>

      <hr class="border-white/5 my-2" />

      <!-- NEW PASSWORD CONFIGURATOR -->
      <div>
        <div class="flex justify-between items-baseline mb-2">
          <%= f.label :password, "New Password", class: "block text-xs font-black uppercase tracking-wider text-orange-200/90" %>
          <span class="text-[10px] text-white/40 font-bold uppercase tracking-wider">Optional</span>
        </div>
        <%= f.password_field :password, autocomplete: "new-password", placeholder: "••••••••",
            class: "block w-full bg-white/10 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/30 text-sm font-semibold focus:outline-none focus:ring-2 focus:ring-orange-300 focus:border-transparent transition shadow-inner" %>
        <% if @minimum_password_length %>
          <p class="text-[10px] text-white/40 mt-1.5 pl-1 font-semibold italic">(<%= @minimum_password_length %> characters minimum requirement)</p>
        <% end %>
      </div>

      <!-- CONFIRM NEW PASSWORD INPUT -->
      <div>
        <%= f.label :password_confirmation, "Confirm New Password", class: "block text-xs font-black uppercase tracking-wider text-orange-200/90 mb-2" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "••••••••",
            class: "block w-full bg-white/10 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/30 text-sm font-semibold focus:outline-none focus:ring-2 focus:ring-orange-300 focus:border-transparent transition shadow-inner" %>
      </div>

      <hr class="border-white/5 my-2" />

      <!-- CONTEXTUAL VALIDATION BLOCK -->
      <div class="bg-[rgba(201,138,75,0.1)] p-4 rounded-2xl border border-[rgba(201,138,75,0.15)] shadow-inner">
        <%= f.label :current_password, class: "block text-xs font-black uppercase tracking-wider text-orange-200 mb-2" %>
        <%= f.password_field :current_password, autocomplete: "current-password", placeholder: "••••••••", required: true,
            class: "block w-full bg-stone-950/40 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/20 text-sm font-semibold focus:outline-none focus:ring-2 focus:ring-orange-300 focus:border-transparent transition shadow-sm" %>
        <p class="text-[10px] text-orange-100/60 mt-2 pl-0.5 font-medium leading-relaxed">Security Requirement: We need your active credential password to commit changes.</p>
      </div>

      <!-- FORM EXECUTION SUBMIT TRIGGER -->
      <div class="pt-2">
        <%= f.submit "Update Profile Settings", class: "block w-full bg-white hover:bg-orange-50 text-stone-900 font-extrabold text-sm py-3.5 rounded-xl transition shadow-lg cursor-pointer tracking-tight text-center" %>
      </div>
    <% end %>
  </div>

  <!-- ISOLATED ACCOUNT DELETION ZONE -->
  <div class="bg-rose-950/20 border border-rose-500/20 rounded-[2rem] p-6 flex flex-col sm:flex-row justify-between items-center gap-4 shadow-xl">
    <div class="text-center sm:text-left">
      <h3 class="text-sm font-black text-rose-300 uppercase tracking-wider">Danger Zone</h3>
      <p class="text-xs text-rose-200/60 font-semibold mt-0.5 max-w-xs leading-normal">Permanently delete your profile credential account data and clear outstanding tickets.</p>
    </div>
    <div>
      <%= button_to "Cancel Account", registration_path(resource_name), 
          data: { confirm: "Are you absolutely certain you want to terminate your registration?", turbo_confirm: "Are you absolutely certain you want to terminate your registration?" }, 
          method: :delete, 
          class: "bg-rose-500/10 hover:bg-rose-500/20 text-rose-300 border border-rose-500/30 font-black px-4 py-2.5 rounded-xl text-xs uppercase tracking-wider transition cursor-pointer shadow-sm tracking-tight shrink-0" %>
    </div>
  </div>

</div>