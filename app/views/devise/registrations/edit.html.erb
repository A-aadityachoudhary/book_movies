<div class="container mx-auto px-4 py-12 max-w-lg space-y-8">
  
  <div class="text-left">
    <%= link_to "← Back", :back, class: "text-sm font-bold text-gray-500 hover:text-indigo-600 transition" %>
  </div>

  <div class="bg-white border border-gray-200 rounded-3xl shadow-xl p-8">
    <div class="mb-6">
      <h1 class="text-2xl font-black text-gray-900">Account Settings</h1>
      <p class="text-sm text-gray-500">Update your email coordinates or security authorization passwords.</p>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-5" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, class: "block text-xs font-bold uppercase tracking-wider text-gray-700 mb-2" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", required: true,
            class: "w-full border border-gray-300 rounded-xl px-4 py-2.5 shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 font-medium text-gray-900" %>
      </div>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <div class="p-3 bg-amber-50 border border-amber-200 rounded-xl text-xs text-amber-700 font-medium">
          Currently waiting verification confirmation for: <span class="font-bold"><%= resource.unconfirmed_email %></span>
        </div>
      <% end %>

      <hr class="border-gray-100 my-2" />

      <div>
        <div class="flex justify-between items-baseline mb-2">
          <%= f.label :password, "New Password", class: "block text-xs font-bold uppercase tracking-wider text-gray-700" %>
          <span class="text-[10px] text-gray-400 italic font-medium">Leave blank if unchanged</span>
        </div>
        <%= f.password_field :password, autocomplete: "new-password", placeholder: "••••••••",
            class: "w-full border border-gray-300 rounded-xl px-4 py-2.5 shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 font-medium text-gray-900" %>
        <% if @minimum_password_length %>
          <p class="text-[10px] text-gray-400 mt-1 pl-1 font-medium italic">(<%= @minimum_password_length %> characters minimum requirement)</p>
        <% end %>
      </div>

      <div>
        <%= f.label :password_confirmation, "Confirm New Password", class: "block text-xs font-bold uppercase tracking-wider text-gray-700 mb-2" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "••••••••",
            class: "w-full border border-gray-300 rounded-xl px-4 py-2.5 shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 font-medium text-gray-900" %>
      </div>

      <hr class="border-gray-100 my-2" />

      <div class="bg-indigo-50/50 p-4 rounded-2xl border border-indigo-100">
        <%= f.label :current_password, class: "block text-xs font-bold uppercase tracking-wider text-indigo-900 mb-2" %>
        <%= f.password_field :current_password, autocomplete: "current-password", placeholder: "••••••••", required: true,
            class: "w-full border border-gray-300 rounded-xl px-4 py-2.5 shadow-sm bg-white focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 font-medium text-gray-900" %>
        <p class="text-[10px] text-indigo-600/80 mt-1.5 pl-1 font-semibold">Security Requirement: We need your active credential token string to commit changes.</p>
      </div>

      <div class="pt-2">
        <%= f.submit "Update Profile Settings", class: "w-full bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 rounded-xl shadow-lg transition cursor-pointer text-center" %>
      </div>
    <% end %>
  </div>

  <div class="bg-red-50/40 border border-red-200 rounded-3xl p-6 flex flex-col sm:flex-row justify-between items-center gap-4">
    <div class="text-center sm:text-left">
      <h3 class="text-sm font-bold text-red-900">Danger Zone Area</h3>
      <p class="text-xs text-red-700 font-medium mt-0.5">Completely terminate your user session profile and clear outstanding wallet data entries.</p>
    </div>
    <div>
      <%= button_to "Cancel Account", registration_path(resource_name), 
          data: { confirm: "Are you absolutely certain you want to terminate your registration?", turbo_confirm: "Are you absolutely certain you want to terminate your registration?" }, 
          method: :delete, 
          class: "bg-white hover:bg-red-50 text-red-600 border border-red-200 font-bold px-4 py-2 rounded-xl text-xs transition cursor-pointer shadow-sm shrink-0" %>
    </div>
  </div>

</div>