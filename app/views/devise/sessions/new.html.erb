<div class="container mx-auto px-4 py-12 max-w-md">
  <div class="bg-white border border-gray-200 rounded-3xl shadow-xl p-8">
    
    <div class="mb-6 text-center">
      <h1 class="text-3xl font-black text-gray-900 tracking-tight">Welcome Back</h1>
      <p class="text-sm text-gray-500 mt-1">Sign in to your wallet to access your active ticket entry passes.</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
      
      <div>
        <%= f.label :email, class: "block text-xs font-bold uppercase tracking-wider text-gray-700 mb-2" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "you@example.com", required: true,
            class: "w-full border border-gray-300 rounded-xl px-4 py-2.5 shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 font-medium text-gray-900" %>
      </div>

      <div>
        <div class="flex justify-between items-center mb-2">
          <%= f.label :password, class: "block text-xs font-bold uppercase tracking-wider text-gray-700" %>
          <%= link_to "Forgot?", new_password_path(resource_name), class: "text-[11px] text-indigo-600 font-bold hover:underline" %>
        </div>
        <%= f.password_field :password, autocomplete: "current-password", placeholder: "••••••••", required: true,
            class: "w-full border border-gray-300 rounded-xl px-4 py-2.5 shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 font-medium text-gray-900" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center">
          <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500 cursor-pointer" %>
          <%= f.label :remember_me, class: "ml-2 text-xs font-semibold text-gray-600 select-none cursor-pointer" %>
        </div>
      <% end %>

      <div class="pt-2">
        <%= f.submit "Sign In", class: "w-full bg-gray-900 hover:bg-gray-800 text-white font-bold py-3 rounded-xl shadow-lg transition cursor-pointer text-center" %>
      </div>
    <% end %>

    <div class="mt-6 pt-6 border-t border-gray-100 text-center text-sm text-gray-500 font-medium">
      New to CineBook? 
      <%= link_to "Create an account", new_registration_path(resource_name), class: "text-indigo-600 font-bold hover:underline" %>
    </div>

  </div>
</div>