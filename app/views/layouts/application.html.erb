<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Book Movies" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Book Movies">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
      body {
        /* INJECTED: Your final vibrant pink-to-apricot linear gradient choice */
        background-image: linear-gradient( 109deg, rgba(160,24,80,1) 11.2%, rgba(201,138,75,1) 81.7% );
        background-attachment: fixed;
      }
    </style>
  </head>

  <body class="min-h-screen flex flex-col font-sans antialiased selection:bg-rose-900 selection:text-white">
    
    <!-- NAVBAR: Kept 100% transparent while spacing elements beautifully -->
    <nav class="bg-transparent py-6 z-50">
      <div class="container mx-auto px-4 flex justify-between items-center">
        <!-- BRAND LOGO: Clean stark white typography that pops against the rich magenta background -->
        <%= link_to "🎬 CineBook", root_path, class: "text-2xl font-black text-white tracking-tighter hover:opacity-90 transition" %>

        <!-- NAVIGATION LINKS: Highly legible white text with soft sunset-rose interactive actions -->
        <div class="flex items-center space-x-6 text-sm font-bold tracking-tight">
          <% if user_signed_in? %>

            <%= link_to can?(:manage, Booking) ? " 🎟️ Sold Tickets" : "🎟️ My Tickets", bookings_path, class: "text-white hover:text-orange-100 transition" %>

            <span class="text-white/20 font-normal">|</span>
            <span class="text-white/80 font-normal"><%= current_user.role.capitalize %>: <span class="text-white font-semibold"><%= current_user.email %></span></span>
            <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "text-rose-200 hover:text-white transition font-bold cursor-pointer" %>
          <% else %>
            <%= link_to "Sign In", new_user_session_path, class: "text-white/90 hover:text-white transition" %>
            <!-- PRIMARY ACTION BUTTON: Styled in solid crisp white with dark stone text to balance the bright background colors -->
            <%= link_to "Sign Up", new_user_registration_path, class: "bg-white hover:bg-orange-50 text-stone-900 px-5 py-2.5 rounded-xl transition shadow-lg font-extrabold tracking-tight" %>
          <% end %>
        </div>
      </div>
    </nav>
    
    <main class="container mx-auto mt-6 mb-12 px-5 flex-grow flex items-center justify-center">
      <div class="w-full">
        <%= yield %>
      </div>
    </main>
  </body>
</html>