<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Book Movies" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Book Movies">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="bg-white border-b border-gray-100 py-4 shadow-sm">
      <div class="container mx-auto px-4 flex justify-between items-center">
        <%= link_to "🎬 CineBook", root_path, class: "text-xl font-black text-indigo-600 tracking-tight" %>

        <div class="flex items-center space-x-6 text-sm font-medium text-gray-600">
          <% if user_signed_in? %>
            <% # 1. REFACTOR: Check ability to manage Booking instead of checking current_user.admin? %>
            <%= link_to can?(:manage, Booking) ? "💼 Master Ledger" : "🎟️ My Tickets", bookings_path, class: "hover:text-indigo-600 transition font-bold text-gray-900" %>

            <span class="text-gray-300">|</span>
            <span class="text-gray-500 font-normal"><%= current_user.role.capitalize %>: <%= current_user.email %></span>
            <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "text-red-500 hover:text-red-600 transition font-semibold cursor-pointer" %>
          <% else %>
            <%= link_to "Sign In", new_user_session_path, class: "bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg transition shadow-sm" %>
          <% end %>
        </div>
      </div>
    </nav>
    
    <main class="container mx-auto mt-28 px-5 flex">
      <%= yield %>
    </main>
  </body>
</html>