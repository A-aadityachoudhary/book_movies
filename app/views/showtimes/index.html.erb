<div class="container mx-auto px-4 py-12 max-w-7xl">
  
  <!-- CATALOG INTERFACE CONTROLS HEADER -->
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-10">
    <div>
      <h1 class="text-4xl font-black text-white tracking-tighter drop-shadow-sm">
        Now Showing
      </h1>
      <p class="text-white/70 text-sm mt-1 font-medium">Select a screening session below to view interactive seating charts and secure your passes.</p>
    </div>
    
    <% if can?(:create, Showtime) %>
      <%= link_to 'Add New Showtime', new_showtime_path, class: "bg-white/10 backdrop-blur-md hover:bg-white/20 text-white font-extrabold px-5 py-3 rounded-xl border border-white/10 shadow-lg transition text-sm tracking-tight" %>
    <% end %>
  </div>

  <!-- SHOWTIME GRID -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @showtimes.each do |showtime| %>
      <!-- CARD HULL CONTAINER -->
      <div class="bg-stone-900/40 backdrop-blur-xl border border-white/10 rounded-[2rem] p-6 shadow-2xl flex flex-col justify-between transform transition duration-300 hover:scale-[1.02] hover:border-white/20 group">
        
        <div>
          <!-- GENRE INTERACTIVE STAMP -->
          <span class="inline-block bg-[rgba(201,138,75,0.2)] text-orange-200 text-xs font-black px-3 py-1.5 rounded-xl uppercase tracking-wider border border-[rgba(201,138,75,0.3)] mb-4">
            <%= showtime.movie.genre %>
          </span>
          
          <!-- MOVIE IDENTIFIER -->
          <h2 class="text-2xl font-black text-white mb-1 tracking-tight leading-snug group-hover:text-orange-100 transition-colors">
            <%= showtime.movie.title %>
          </h2>
          
          <!-- RUNTIME SUBMETRIC -->
          <p class="text-xs text-white/60 font-semibold uppercase tracking-wider mb-6 flex items-center gap-1.5">
            ⏱️ <%= showtime.movie.duration %> mins
          </p>
        </div>
        
        <!-- TRANSACTION MATRIX DATA LAYOUT -->
        <div class="border-t border-white/10 pt-5 flex justify-between items-center mt-auto">
          <div>
            <!-- CALENDAR TIMESTAMP -->
            <p class="text-sm font-extrabold text-white tracking-tight"><%= showtime.start_time.strftime("%A, %b %d") %></p>
            <!-- THEATER SCREEN COORDINATE -->
            <p class="text-xs text-white/50 font-medium mt-0.5"><%= showtime.start_time.strftime("%I:%M %p") %> • Screen <%= showtime.screen.screen_number %></p>
          </div>         
          <div class="text-right">
            <!-- RETAIL FINANCIAL SUMMARY -->
            <p class="text-xl font-black text-white tracking-tight mb-2"><%= number_to_currency(showtime.price) %></p>
            <!-- TARGET BOOKING SELECTION ACTION -->
            <%= link_to 'Book Tickets', showtime_path(showtime), class: "inline-block bg-white hover:bg-orange-50 text-stone-900 font-extrabold text-xs px-4 py-2.5 rounded-xl transition shadow-md tracking-tight" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>