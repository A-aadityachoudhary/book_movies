<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-4xl font-extrabold text-gray-900 tracking-tight">Now Showing</h1>
    
    <% if can?(:create, Showtime) %>
      <%= link_to 'Add New Showtime', new_showtime_path, class: "bg-indigo-600 hover:bg-indigo-700 text-white font-semibold px-4 py-2 rounded-lg shadow transition" %>
    <% end %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @showtimes.each do |showtime| %>
      <div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-6 hover:shadow-md transition">
        <span class="inline-block bg-indigo-50 text-indigo-700 text-xs font-semibold px-2.5 py-1 rounded-full mb-4">
          <%= showtime.movie.genre %>
        </span>
        <h2 class="text-xl font-bold text-gray-900 mb-1"><%= showtime.movie.title %></h2>
        <p class="text-sm text-gray-500 mb-4">Duration: <%= showtime.movie.duration %> mins</p>
        
        <div class="border-t border-gray-100 pt-4 flex justify-between items-center">
          <div>
            <p class="text-sm font-medium text-gray-900"><%= showtime.start_time.strftime("%A, %b %d") %></p>
            <p class="text-xs text-gray-500"><%= showtime.start_time.strftime("%I:%M %p") %> • Screen <%= showtime.screen.screen_number %></p>
          </div>
          <div class="text-right">
            <p class="text-lg font-bold text-gray-900 mb-2"><%= number_to_currency(showtime.price) %></p>
            <%= link_to 'Book Tickets', showtime_path(showtime), class: "bg-gray-900 hover:bg-gray-800 text-white text-sm font-medium px-4 py-2 rounded-lg transition" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>