<div class="container mx-auto px-4 py-12 max-w-lg">
  <% if can?(:create, Showtime) %>
    <!-- FROSTED WIZARD CONTAINER CARD -->
    <div class="bg-stone-900/40 backdrop-blur-xl border border-white/10 rounded-[2rem] p-8 shadow-2xl">
      
      <div class="mb-6">
        <h1 class="text-2xl font-black text-white tracking-tight">Create New Showtime</h1>
        <p class="text-xs text-white/60 mt-1 font-medium">Schedule a movie screening and initialize room seating allocations.</p>
      </div>

      <%= form_with model: @showtime, local: true, class: "space-y-5" do |f| %>
        
        <% if @showtime.errors.any? %>
          <!-- ERROR PANEL -->
          <div class="p-4 bg-rose-500/20 border border-rose-500/30 rounded-2xl text-xs font-semibold text-rose-200">
            <p class="font-bold mb-1 text-rose-100">Please correct the following errors:</p>
            <ul class="list-disc pl-5 space-y-1">
              <% @showtime.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <%= f.label :movie_title, "Movie Title", class: "block text-xs font-black uppercase tracking-wider text-orange-200/90 mb-2" %>
          <%= f.text_field :movie_title, placeholder: "e.g., Interstellar", required: true,
              class: "block w-full bg-white/10 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/30 text-sm font-semibold focus:outline-none focus:ring-2 focus:ring-orange-300 focus:border-transparent transition shadow-inner" %>
        </div>
              
        <div>
          <%= f.label :screen_number, "Screen Room Number", class: "block text-xs font-black uppercase tracking-wider text-orange-200/90 mb-2" %>
          <%= f.number_field :screen_number, placeholder: "e.g., 5", required: true, min: 1,
              class: "block w-full bg-white/10 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/30 text-sm font-semibold focus:outline-none focus:ring-2 focus:ring-orange-300 focus:border-transparent transition shadow-inner" %>
        </div>

        <div>
          <%= f.label :price, "Ticket Price ($)", class: "block text-xs font-black uppercase tracking-wider text-orange-200/90 mb-2" %>
          <%= f.number_field :price, step: "0.01", placeholder: "12.50", 
              class: "block w-full bg-white/10 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/30 text-sm font-semibold focus:outline-none focus:ring-2 focus:ring-orange-300 focus:border-transparent transition shadow-inner" %>
        </div>

        <div>
          <%= f.label :start_time, "Screening Date & Time", class: "block text-xs font-black uppercase tracking-wider text-orange-200/90 mb-2" %>
          <%= f.datetime_local_field :start_time, 
              class: "block w-full bg-white/10 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/30 text-sm font-semibold focus:outline-none focus:ring-2 focus:ring-orange-300 focus:border-transparent transition shadow-inner [color-scheme:dark]" %>
        </div>

        <!-- ACTION CONTROL BAR -->
        <div class="pt-4 flex space-x-3">
          <%= link_to "Cancel", root_path, class: "w-1/3 bg-white/10 hover:bg-white/20 text-white font-extrabold text-center py-3 rounded-xl transition text-sm tracking-tight border border-white/5" %>
          <%= f.submit "Create Showtime", class: "w-2/3 bg-white hover:bg-orange-50 text-stone-900 font-extrabold py-3 rounded-xl shadow-lg transition cursor-pointer text-sm tracking-tight" %>
        </div>

      <% end %>

    </div>
  <% else %>
    <!-- SECURITY GUARD EXCEPTION BLOCK -->
    <div class="bg-stone-900/40 backdrop-blur-xl border border-white/10 rounded-[2rem] p-8 text-center shadow-2xl">
      <div class="text-3xl mb-3">🛡️</div>
      <p class="text-white font-black text-xl mb-1">Access Denied</p>
      <p class="text-white/70 text-sm mb-6">You lack administrative access privileges required to initialize showtime screening inventory.</p>
      <%= link_to "Back to Home", root_path, class: "inline-block bg-white hover:bg-orange-50 text-stone-900 font-extrabold px-6 py-3 rounded-xl transition shadow-md text-sm" %>
    </div>
  <% end %>
</div>