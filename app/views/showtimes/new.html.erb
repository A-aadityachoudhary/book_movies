<div class="container mx-auto px-4 py-12 max-w-lg">
  <div class="bg-white border border-gray-200 rounded-3xl shadow-xl p-8">
    
    <div class="mb-6">
      <h1 class="text-2xl font-black text-gray-900">Create New Showtime</h1>
      <p class="text-sm text-gray-500">Schedule a movie screening and initialize room seating allocations.</p>
    </div>

    <%= form_with model: @showtime, local: true, class: "space-y-5" do |f| %>
      
      <% if @showtime.errors.any? %>
        <div class="p-4 bg-red-50 border border-red-200 text-red-700 text-sm rounded-xl">
          <p class="font-bold mb-1">Please correct the following errors:</p>
          <ul class="list-disc pl-5 space-y-1">
            <% @showtime.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-5">
          <%= f.label :movie_title, "Movie Title", class: "block text-xs font-bold uppercase tracking-wider text-gray-700 mb-2" %>
          <%= f.text_field :movie_title, placeholder: "e.g., Interstellar", required: true,
              class: "w-full border border-gray-300 rounded-xl px-4 py-2.5 shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 font-medium" %>
        </div>
            
        <div class="mb-5">
          <%= f.label :screen_number, "Screen Room Number", class: "block text-xs font-bold uppercase tracking-wider text-gray-700 mb-2" %>
          <%= f.number_field :screen_number, placeholder: "e.g., 5", required: true, min: 1,
              class: "w-full border border-gray-300 rounded-xl px-4 py-2.5 shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 font-medium" %>
        </div>

      <div>
        <%= f.label :price, "Ticket Price ($)", class: "block text-xs font-bold uppercase tracking-wider text-gray-700 mb-2" %>
        <%= f.number_field :price, step: "0.01", placeholder: "12.50", 
            class: "w-full border border-gray-300 rounded-xl px-4 py-2.5 shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 font-medium" %>
      </div>

      <div>
        <%= f.label :start_time, "Screening Date & Time", class: "block text-xs font-bold uppercase tracking-wider text-gray-700 mb-2" %>
        <%= f.datetime_local_field :start_time, 
            class: "w-full border border-gray-300 rounded-xl px-4 py-2.5 shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 font-medium text-gray-700" %>
      </div>

      <div class="pt-4 flex space-x-3">
        <%= link_to "Cancel", root_path, class: "w-1/3 bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold text-center py-3 rounded-xl transition" %>
        <%= f.submit "Create Showtime", class: "w-2/3 bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 rounded-xl shadow-lg transition cursor-pointer" %>
      </div>

    <% end %>

  </div>
</div>